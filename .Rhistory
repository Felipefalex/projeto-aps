}
saida
}
txt <- function(x) {
x |>
as.character() |>
stringr::str_squish() |>
dplyr::na_if("")
}
num_br <- function(x) {
x |>
as.character() |>
stringr::str_replace_all(",", ".") |>
readr::parse_number(
locale = readr::locale(decimal_mark = ".")
)
}
extrair_ano <- function(arquivo) {
basename(arquivo) |>
stringr::str_extract("20\\d{2}") |>
as.integer()
}
normalizar_codigo <- function(x) {
x |>
as.character() |>
stringr::str_squish() |>
stringr::str_replace("\\.0$", "") |>
stringr::str_extract("[0-9]+")
}
# ------------------------------------------------------------
# 4. Padronização das bases anuais de endereço
# ------------------------------------------------------------
padronizar_endereco <- function(arquivo) {
df <- ler_csv_base(arquivo)
ano_base <- extrair_ano(arquivo)
tibble::tibble(
ano = ano_base,
nome_rede = txt(coluna(df, "nomedep")),
diretoria_ensino = txt(coluna(df, "de")),
municipio = txt(coluna(df, "mun")),
cd_ibge = txt(coluna(df, "cd_ibge")),
distrito = txt(coluna(df, "distr")),
cod_esc = txt(coluna(df, "cod_esc")),
codescmec = txt(coluna(df, "codescmec")),
nome_escola = txt(coluna(df, "nomesc")),
situacao_original = txt(
coluna_primeira(df, c("situacao", "codsit"))
),
tipo_escola = txt(coluna(df, "tipoesc")),
endereco = txt(coluna(df, "endesc")),
numero = txt(coluna(df, "numesc")),
complemento = txt(
coluna_primeira(df, c("complemento", "complend"))
),
cep = txt(coluna(df, "cep")),
bairro = txt(coluna(df, "baiesc")),
zona = txt(coluna(df, "zona")),
latitude_original = txt(
coluna_primeira(df, c("ds_latitude", "latitude"))
),
longitude_original = txt(
coluna_primeira(df, c("ds_longitude", "longitude"))
),
cod_vinc = txt(coluna(df, "codvinc"))
) |>
dplyr::mutate(
cod_esc_num = suppressWarnings(as.numeric(cod_esc)),
codescmec_num = suppressWarnings(as.numeric(codescmec)),
latitude = num_br(latitude_original),
longitude = num_br(longitude_original),
situacao = dplyr::case_when(
stringr::str_to_upper(situacao_original) %in% c("ATIVA", "ATIVO", "1") ~ "Ativa",
stringr::str_to_upper(situacao_original) %in% c("INATIVA", "INATIVO", "0") ~ "Inativa",
TRUE ~ situacao_original
),
id_escola = dplyr::case_when(
!is.na(codescmec_num) & codescmec_num > 0 ~ paste0("mec_", codescmec),
!is.na(cod_esc_num) ~ paste0("cod_", cod_esc),
TRUE ~ paste0("sem_codigo_", ano, "_", dplyr::row_number())
)
)
}
# ------------------------------------------------------------
# 5. Construção da base painel escola-ano
# ------------------------------------------------------------
base_enderecos_bruta <- arquivos_endereco |>
sort() |>
purrr::map_dfr(padronizar_endereco)
base_painel_escolas <- base_enderecos_bruta |>
dplyr::arrange(
ano,
id_escola,
dplyr::desc(!is.na(codescmec_num) & codescmec_num > 0),
dplyr::desc(!is.na(latitude)),
dplyr::desc(!is.na(longitude))
) |>
dplyr::distinct(ano, id_escola, .keep_all = TRUE)
# ------------------------------------------------------------
# 6. Tratamento da base de INSE
# ------------------------------------------------------------
inse_raw <- ler_csv_base(arquivo_inse)
possiveis_colunas_inse <- c(
"nivel_socioeconomico_dos_alunos",
"nivel_socioeconomico",
"inse"
)
coluna_inse <- possiveis_colunas_inse[
possiveis_colunas_inse %in% names(inse_raw)
][1]
if (is.na(coluna_inse)) {
coluna_inse <- names(inse_raw)[
stringr::str_detect(names(inse_raw), "socioeconomico|inse")
][1]
}
if (is.na(coluna_inse)) {
stop("Não foi possível identificar a coluna do índice socioeconômico.")
}
inse_2019 <- tibble::tibble(
cod_esc = txt(coluna(inse_raw, "cod_esc")),
nome_escola_inse = txt(coluna(inse_raw, "nomesc")),
diretoria_ensino_inse = txt(coluna(inse_raw, "dir")),
municipio_inse = txt(coluna(inse_raw, "mun")),
inse_2019 = num_br(inse_raw[[coluna_inse]])
) |>
dplyr::arrange(
cod_esc,
dplyr::desc(!is.na(inse_2019))
) |>
dplyr::distinct(cod_esc, .keep_all = TRUE)
# ------------------------------------------------------------
# 7. Base final preliminar
# ------------------------------------------------------------
base_final <- base_painel_escolas |>
dplyr::left_join(inse_2019, by = "cod_esc")
# ------------------------------------------------------------
# 1. Configuração da Base dos Dados
# ------------------------------------------------------------
billing_project_id <- "SEU_PROJETO_AQUI"
basedosdados::set_billing_id(billing_project_id)
# ------------------------------------------------------------
# 2. Expansão da base para 2015-2017
# ------------------------------------------------------------
base_2018 <- base_final |>
dplyr::filter(ano == 2018)
base_2018_replicada <- purrr::map_dfr(
2015:2017,
~ base_2018 |>
dplyr::mutate(
ano = .x,
endereco_replicado_2018 = 1L,
ano_origem_endereco = 2018L
)
)
base_final <- base_final |>
dplyr::mutate(
endereco_replicado_2018 = 0L,
ano_origem_endereco = ano
) |>
dplyr::bind_rows(base_2018_replicada) |>
dplyr::filter(ano >= 2015, ano <= 2025) |>
dplyr::mutate(
id_escola_bd = normalizar_codigo(codescmec)
) |>
dplyr::filter(!is.na(id_escola_bd)) |>
dplyr::arrange(ano, id_escola) |>
dplyr::distinct(ano, id_escola, .keep_all = TRUE)
ids_escolas_bd <- base_final |>
dplyr::distinct(id_escola_bd) |>
dplyr::pull(id_escola_bd)
ids_sql <- paste0("'", ids_escolas_bd, "'", collapse = ", ")
