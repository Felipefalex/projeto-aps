# 3. Funções auxiliares da Base dos Dados
# ------------------------------------------------------------
consultar_colunas_bd <- function(dataset, tabela) {
query <- glue::glue("
SELECT column_name
FROM `basedosdados.{dataset}.INFORMATION_SCHEMA.COLUMNS`
WHERE table_name = '{tabela}'
ORDER BY ordinal_position
")
basedosdados::read_sql(
query = query,
billing_project_id = billing_project_id
) |>
dplyr::pull(column_name)
}
montar_select_sql <- function(colunas, alias = "t") {
paste0(alias, ".`", colunas, "`", collapse = ",\n    ")
}
