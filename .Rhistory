# ------------------------------------------------------------
# 1. Configuração da Base dos Dados
# ------------------------------------------------------------
billing_project_id <- "SEU_PROJETO_AQUI"
basedosdados::set_billing_id(billing_project_id)
uf_foco <- "SP"
prefixo_ibge_uf <- "35"
# ------------------------------------------------------------
# 2. Função auxiliar para código da escola
# ------------------------------------------------------------
normalizar_codigo <- function(x) {
x |>
as.character() |>
stringr::str_squish() |>
stringr::str_replace("\\.0$", "") |>
stringr::str_extract("[0-9]+")
}
# ------------------------------------------------------------
# 3. Filtro local: manter apenas escolas de SP
# ------------------------------------------------------------
base_final <- base_final |>
dplyr::mutate(
cd_ibge_norm = normalizar_codigo(cd_ibge),
id_escola_bd = normalizar_codigo(codescmec)
) |>
dplyr::filter(
is.na(cd_ibge_norm) | stringr::str_starts(cd_ibge_norm, prefixo_ibge_uf),
!is.na(id_escola_bd)
)
# ------------------------------------------------------------
# 4. Expansão da base para 2015-2017 usando cadastro de 2018
# ------------------------------------------------------------
base_2018 <- base_final |>
dplyr::filter(ano == 2018)
base_2018_replicada <- purrr::map_dfr(
2015:2017,
\(ano_ref) {
base_2018 |>
dplyr::mutate(
ano = ano_ref,
endereco_replicado_2018 = 1L,
ano_origem_endereco = 2018L
)
}
)
base_final <- base_final |>
dplyr::mutate(
endereco_replicado_2018 = 0L,
ano_origem_endereco = ano
) |>
dplyr::bind_rows(base_2018_replicada) |>
dplyr::filter(ano >= 2015, ano <= 2025) |>
dplyr::arrange(ano, id_escola) |>
dplyr::distinct(ano, id_escola, .keep_all = TRUE)
ids_escolas_bd <- base_final |>
dplyr::distinct(id_escola_bd) |>
dplyr::pull(id_escola_bd)
if (length(ids_escolas_bd) == 0) {
stop("Nenhum código de escola válido foi encontrado para consulta na Base dos Dados.")
}
ids_sql <- paste0("'", ids_escolas_bd, "'", collapse = ", ")
# ------------------------------------------------------------
# 5. Consulta otimizada ao Censo Escolar
# ------------------------------------------------------------
query_censo <- glue::glue("
WITH escolas_base AS (
SELECT id_escola
FROM UNNEST([{ids_sql}]) AS id_escola
)
SELECT
CAST(t.ano AS INT64) AS ano,
CAST(t.id_escola AS STRING) AS id_escola_bd,
t.quantidade_computador_aluno,
t.desktop_aluno,
t.quantidade_desktop_aluno,
t.computador_portatil_aluno,
t.quantidade_computador_portatil_aluno,
t.tablet_aluno,
t.quantidade_tablet_aluno,
t.acesso_internet_computador,
t.laboratorio_informatica,
t.internet_alunos,
t.acesso_internet_dispositivo_pessoal
FROM `basedosdados.br_inep_censo_escolar.escola` AS t
INNER JOIN escolas_base AS e
ON CAST(t.id_escola AS STRING) = e.id_escola
WHERE CAST(t.ano AS INT64) BETWEEN 2015 AND 2025
AND t.sigla_uf = '{uf_foco}'
")
censo_escola <- basedosdados::read_sql(
query = query_censo,
billing_project_id = billing_project_id
) |>
janitor::clean_names() |>
dplyr::mutate(
ano = as.integer(ano),
id_escola_bd = normalizar_codigo(id_escola_bd)
) |>
dplyr::distinct(ano, id_escola_bd, .keep_all = TRUE)
