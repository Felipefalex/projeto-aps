# ------------------------------------------------------------
# 3. Funções auxiliares
# ------------------------------------------------------------
ler_csv_base <- function(arquivo) {
readr::read_delim(
file = arquivo,
delim = ";",
locale = readr::locale(
encoding = "Latin1",
decimal_mark = ","
),
col_types = readr::cols(.default = readr::col_character()),
trim_ws = TRUE,
show_col_types = FALSE
) |>
janitor::clean_names()
}
coluna <- function(df, nome) {
if (nome %in% names(df)) {
as.character(df[[nome]])
} else {
rep(NA_character_, nrow(df))
}
}
coluna_primeira <- function(df, nomes) {
nomes_existentes <- nomes[nomes %in% names(df)]
if (length(nomes_existentes) == 0) {
return(rep(NA_character_, nrow(df)))
}
saida <- as.character(df[[nomes_existentes[1]]])
if (length(nomes_existentes) > 1) {
for (nm in nomes_existentes[-1]) {
saida <- dplyr::coalesce(saida, as.character(df[[nm]]))
}
}
saida
}
txt <- function(x) {
x |>
as.character() |>
stringr::str_squish() |>
dplyr::na_if("")
}
num_br <- function(x) {
x |>
as.character() |>
stringr::str_replace_all(",", ".") |>
readr::parse_number(
locale = readr::locale(decimal_mark = ".")
)
}
extrair_ano <- function(arquivo) {
basename(arquivo) |>
stringr::str_extract("20\\d{2}") |>
as.integer()
}
normalizar_codigo <- function(x) {
x |>
as.character() |>
stringr::str_squish() |>
stringr::str_replace("\\.0$", "") |>
stringr::str_extract("[0-9]+")
}
